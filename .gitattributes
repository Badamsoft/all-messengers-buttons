# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Binary files – never modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.zip binary

# PHP / JS / CSS – always LF
*.php text eol=lf
*.js  text eol=lf
*.css text eol=lf
*.txt text eol=lf
*.md  text eol=lf
*.json text eol=lf
*.pot  text eol=lf

# Export-ignore: files not needed in the release zip
.gitignore   export-ignore
.gitattributes export-ignore
README.md    export-ignore
